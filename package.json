{
  "name": "neussh",
  "version": "1.0.0",
  "description": "NeuSSH - Modern SSH Connection Manager for macOS and Windows. Better than PuTTY.",
  "main": "src/main.js",
  "homepage": "https://github.com/neussh/neussh",
  "repository": {
    "type": "git",
    "url": "https://github.com/neussh/neussh.git"
  },
  "bugs": {
    "url": "https://github.com/neussh/neussh/issues"
  },
  "author": "NeuSSH Team <hello@neussh.dev>",
  "license": "MIT",
  "keywords": [
    "ssh",
    "terminal",
    "putty",
    "electron",
    "remote",
    "server",
    "devops",
    "macos",
    "windows"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "cd renderer && vite",
    "build": "npm run build:renderer && electron-builder --publish never",
    "build:renderer": "cd renderer && vite build",
    "build:win": "npm run build:renderer && electron-builder --win --publish never",
    "build:mac": "npm run build:renderer && electron-builder --mac --publish never",
    "build:all": "npm run build:renderer && electron-builder --win --mac --publish never",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint src renderer/src --ext .js,.jsx",
    "lint:fix": "eslint src renderer/src --ext .js,.jsx --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "rimraf dist renderer/dist node_modules/.vite",
    "release:win": "npm run build:win",
    "release:mac": "npm run build:mac"
  },
  "build": {
    "appId": "dev.neussh.app",
    "productName": "NeuSSH",
    "copyright": "Copyright © 2024 NeuSSH",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "LICENSE",
      "README.md"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ssh2/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "publisherName": "NeuSSH",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NeuSSH",
      "license": "LICENSE",
      "artifactName": "NeuSSH-Setup-${version}.${ext}",
      "uninstallDisplayName": "NeuSSH",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "NeuSSH-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "ssh2": "^1.16.0",
    "electron-store": "^8.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "lucide-react": "^0.378.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0"
  }
}
